; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="stack_overflow"
run/main_scene="res://scenes/core/main_menu.tscn"
config/features=PackedStringArray("4.4", "GL Compatibility")

[autoload]

RNG="*res://scripts/autoloads/rng.gd"
SettingsManager="*res://scripts/autoloads/settings_manager.gd"
GameManager="*res://scripts/autoloads/game_manager.gd"
CollectionManager="*res://scripts/autoloads/collection_manager.gd"
AudioManager="*res://scripts/autoloads/audio_manager.gd"
HistoryManager="*res://scripts/autoloads/history_manager.gd"
AchievementManager="*res://scripts/autoloads/achievement_manager.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"
window/stretch/aspect="keep"

[gui]

theme/custom="res://scenes/ui/game_theme.tres"

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
